{
  "name": "pbo-parser",
  "version": "1.0.0",
  "description": "Parsing pbo to extract slots, briefing, etc from any .pbo file with a mission.sqm",
  "homepage": "https://github.com/Arma-Serious-Platform/pbo-parser#readme",
  "bugs": {
    "url": "https://github.com/Arma-Serious-Platform/pbo-parser/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arma-Serious-Platform/pbo-parser.git"
  },
  "license": "MIT",
  "author": "Agentos",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc && npm run copy:assets",
    "dev": "nodemon --exec \"node --loader ts-node/esm\" src/main.ts",
    "copy:assets": "rsync -a --exclude='*.ts' --exclude='*.tsx' src/ dist/",
    "start": "node dist/main.js"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1"
  }
}
